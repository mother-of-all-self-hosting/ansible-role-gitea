TZ={{ gitea_environment_variables_tz }}

USER_UID={{ gitea_uid }}
USER_GID={{ gitea_gid }}

GITEA__server__ROOT_URL={{ gitea_config_root_url }}

GITEA__server__SSH_PORT={{ gitea_container_ssh_port }}
GITEA__server__SSH_LISTEN_PORT={{ gitea_config_server_ssh_listen_port }}

GITEA__server__MINIMUM_KEY_SIZE_CHECK={{ gitea_config_server_minimum_key_size_check | to_json }}

{% if gitea_database_type == 'mysql' %}
GITEA__database__DB_TYPE={{ gitea_database_type }}
GITEA__database__HOST={{ gitea_database_mysql_hostname }}:{{ gitea_database_mysql_port }}
GITEA__database__USER={{ gitea_database_mysql_username }}
GITEA__database__PASSWD={{ gitea_database_mysql_password }}
GITEA__database__NAME={{ gitea_database_name }}
{% endif %}
{% if gitea_database_type == 'postgres' %}
GITEA__database__DB_TYPE={{ gitea_database_type }}
GITEA__database__HOST={{ gitea_database_postgres_hostname }}:{{ gitea_database_postgres_port }}
GITEA__database__USER={{ gitea_database_postgres_username }}
GITEA__database__PASSWD={{ gitea_database_postgres_password }}
GITEA__database__NAME={{ gitea_database_name }}
{% endif %}

GITEA____RUN_USER={{ gitea_config_run_user }}

GITEA__service__ENABLE_NOTIFY_MAIL={{ gitea_config_service_enable_notify_email | to_json }}

{% if gitea_config_mailer_enabled %}
GITEA__mailer__ENABLED=true
GITEA__mailer__FROM={{ gitea_config_mailer_from }}
GITEA__mailer__PROTOCOL={{ gitea_config_mailer_protocol }}
GITEA__mailer__SMTP_ADDR={{ gitea_config_mailer_smtp_addr }}
GITEA__mailer__SMTP_PORT={{ gitea_config_mailer_smtp_port }}
GITEA__mailer__USER={{ gitea_config_mailer_user }}
GITEA__mailer__PASSWD={{ gitea_config_mailer_passwd }}
{% endif %}

GITEA__cache__ADAPTER={{ gitea_config_cache_adapter }}

{% if gitea_config_cache_adapter == 'memory' %}
{% elif gitea_config_cache_adapter == 'redis' %}
GITEA__cache__HOST=redis://{{ gitea_redis_username }}:{{ gitea_redis_password }}@{{ gitea_redis_hostname }}:{{ gitea_redis_port }}/{{ gitea_redis_database }}?pool_size=100&idle_timeout=180s
{% elif gitea_config_cache_adapter == 'redis-cluster' %}
GITEA__cache__HOST=redis+cluster://{{ gitea_redis_username }}:{{ gitea_redis_password }}@{{ gitea_redis_hostname }}:{{ gitea_redis_port }}/{{ gitea_redis_database }}?pool_size=100&idle_timeout=180s
{% else %}
GITEA__cache__HOST={{ gitea_config_cache_host }}
{% endif %}

{{ gitea_environment_variables_additional_variables }}
