{% if gitea_container_labels_traefik_enabled or gitea_container_labels_traefik_tcp_enabled %}
traefik.enable=true

{% if gitea_container_labels_traefik_docker_network %}
traefik.docker.network={{ gitea_container_labels_traefik_docker_network }}
{% endif %}

{% if gitea_container_labels_traefik_enabled %}

{% set middlewares = [] %}

{% if gitea_container_labels_traefik_compression_middleware_enabled %}
{% set middlewares = middlewares + [gitea_container_labels_traefik_compression_middleware_name] %}
{% endif %}

{% if gitea_container_labels_traefik_path_prefix != '/' %}
traefik.http.middlewares.{{ gitea_identifier }}-slashless-redirect.redirectregex.regex=^({{ gitea_container_labels_traefik_path_prefix | quote }})$
traefik.http.middlewares.{{ gitea_identifier }}-slashless-redirect.redirectregex.replacement=${1}/
{% set middlewares = middlewares + [gitea_identifier + '-slashless-redirect'] %}
{% endif %}

{% if gitea_container_labels_traefik_path_prefix != '/' %}
traefik.http.middlewares.{{ gitea_identifier }}-strip-prefix.stripprefix.prefixes={{ gitea_container_labels_traefik_path_prefix }}
{% set middlewares = middlewares + [gitea_identifier + '-strip-prefix'] %}
{% endif %}

{% if gitea_container_labels_traefik_additional_request_headers.keys() | length > 0 %}
{% for name, value in gitea_container_labels_traefik_additional_request_headers.items() %}
traefik.http.middlewares.{{ gitea_identifier }}-add-request-headers.headers.customrequestheaders.{{ name }}={{ value }}
{% endfor %}
{% set middlewares = middlewares + [gitea_identifier + '-add-request-headers'] %}
{% endif %}

{% if gitea_container_labels_traefik_additional_response_headers.keys() | length > 0 %}
{% for name, value in gitea_container_labels_traefik_additional_response_headers.items() %}
traefik.http.middlewares.{{ gitea_identifier }}-add-response-headers.headers.customresponseheaders.{{ name }}={{ value }}
{% endfor %}
{% set middlewares = middlewares + [gitea_identifier + '-add-response-headers'] %}
{% endif %}

traefik.http.routers.{{ gitea_identifier }}.rule={{ gitea_container_labels_traefik_rule }}
{% if gitea_container_labels_traefik_priority | int > 0 %}
traefik.http.routers.{{ gitea_identifier }}.priority={{ gitea_container_labels_traefik_priority }}
{% endif %}
traefik.http.routers.{{ gitea_identifier }}.service={{ gitea_identifier }}
{% if middlewares | length > 0 %}
traefik.http.routers.{{ gitea_identifier }}.middlewares={{ middlewares | join(',') }}
{% endif %}
traefik.http.routers.{{ gitea_identifier }}.entrypoints={{ gitea_container_labels_traefik_entrypoints }}
traefik.http.routers.{{ gitea_identifier }}.tls={{ gitea_container_labels_traefik_tls | to_json }}
{% if gitea_container_labels_traefik_tls %}
traefik.http.routers.{{ gitea_identifier }}.tls.certResolver={{ gitea_container_labels_traefik_tls_certResolver }}
{% endif %}

traefik.http.services.{{ gitea_identifier }}.loadbalancer.server.port={{ gitea_container_http_port }}

{% if gitea_container_labels_traefik_metrics_enabled %}
########################################################################
#                                                                      #
# Metrics                                                              #
#                                                                      #
########################################################################

{% set middlewares = gitea_container_labels_traefik_metrics_middlewares %}

{% if gitea_container_labels_traefik_metrics_middleware_basic_auth_enabled %}
traefik.http.middlewares.{{ gitea_identifier }}-metrics-basic-auth.basicauth.users={{ gitea_container_labels_traefik_metrics_middleware_basic_auth_users }}
{% set middlewares = middlewares + [gitea_identifier + '-metrics-basic-auth'] %}
{% endif %}

traefik.http.middlewares.{{ gitea_identifier }}-metrics-replace-path.replacepath.path=/metrics
{% set middlewares = middlewares + [gitea_identifier + '-metrics-replace-path'] %}

traefik.http.routers.{{ gitea_identifier }}-metrics.rule={{ gitea_container_labels_traefik_metrics_rule }}

{% if gitea_container_labels_traefik_metrics_priority | int > 0 %}
traefik.http.routers.{{ gitea_identifier }}-metrics.priority={{ gitea_container_labels_traefik_metrics_priority }}
{% endif %}

traefik.http.routers.{{ gitea_identifier }}-metrics.service={{ gitea_identifier }}-metrics

{% if middlewares | length > 0 %}
traefik.http.routers.{{ gitea_identifier }}-metrics.middlewares={{ middlewares | join(',') }}
{% endif %}

traefik.http.routers.{{ gitea_identifier }}-metrics.entrypoints={{ gitea_container_labels_traefik_metrics_entrypoints }}

traefik.http.routers.{{ gitea_identifier }}-metrics.tls={{ gitea_container_labels_traefik_metrics_tls | to_json }}
{% if gitea_container_labels_traefik_metrics_tls %}
traefik.http.routers.{{ gitea_identifier }}-metrics.tls.certResolver={{ gitea_container_labels_traefik_metrics_tls_certResolver }}
{% endif %}

traefik.http.services.{{ gitea_identifier }}-metrics.loadbalancer.server.port={{ gitea_container_metrics_port }}

########################################################################
#                                                                      #
# /Metrics                                                             #
#                                                                      #
########################################################################
{% endif %}

{% endif %}

{% endif %}

{% if gitea_container_labels_traefik_tcp_enabled and gitea_container_ssh_host_bind_port %}
########################################################################
#                                                                      #
# SSH                                                                  #
#                                                                      #
########################################################################

traefik.tcp.routers.{{ gitea_identifier }}.rule={{ gitea_container_labels_traefik_tcp_rule }}
{% if gitea_container_labels_traefik_tcp_priority | int > 0 %}
traefik.tcp.routers.{{ gitea_identifier }}.priority={{ gitea_container_labels_traefik_tcp_priority }}
{% endif %}
traefik.tcp.routers.{{ gitea_identifier }}.service={{ gitea_identifier }}
traefik.tcp.routers.{{ gitea_identifier }}.entrypoints={{ gitea_container_labels_traefik_tcp_entrypoints }}

traefik.tcp.services.{{ gitea_identifier }}.loadbalancer.server.port={{ gitea_config_server_ssh_listen_port }}

########################################################################
#                                                                      #
# /SSH                                                                 #
#                                                                      #
########################################################################
{% endif %}

{% for arg in gitea_container_labels_additional_labels %}
{{ arg }}
{% endfor %}
